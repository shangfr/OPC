# ============================================================
# OPCBot 环境变量配置
# ============================================================

# === 必需 ===

# NextAuth JWT 签名密钥
# 生成方式: openssl rand -base64 32
AUTH_SECRET=****

# PostgreSQL 数据库连接字符串 (pooler 模式，日常查询用)
POSTGRES_URL=postgresql://user:password@host/dbname?sslmode=require

# PostgreSQL 直连 URL（不含 -pooler），用于数据库迁移等 DDL 操作
POSTGRES_URL_NON_POOLING=postgresql://user:password@host/dbname?sslmode=require

# === AI 模型 API Key ===

# 智谱 AI (zhipuai)
ZHIPU_API_KEY=****
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek
DEEPSEEK_API_KEY=****

# === 管理 ===

# 管理员邮箱（逗号分隔）
# 注意：此配置仅用于初始化管理员，用户注册后需运行 scripts/sync-admin-roles.ts 同步到数据库
# 或者直接通过用户管理页面设置角色为 admin
ADMIN_EMAILS=your@email.com

# === 可选 ===

# 阿里云 OSS 文件存储（头像上传、附件上传、工单表单存储）
# 非 Vercel 部署推荐使用 OSS 替代 Vercel Blob
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=****
OSS_ACCESS_KEY_SECRET=****
OSS_BUCKET=your-bucket-name
# OSS_ENDPOINT 可省略，默认根据 REGION 自动拼接
# OSS_ENDPOINT=https://oss-cn-hangzhou.aliyuncs.com
# OSS_PUBLIC_DOMAIN 为 CDN/自定义域名（可选），配置后上传文件返回的 URL 会使用此域名
# OSS_PUBLIC_DOMAIN=https://cdn.example.com

# Redis 缓存（IP 限流等，不配置则跳过限流）
# REDIS_URL=redis://localhost:6379

# 站点公开 URL（用于 SEO metadataBase，默认 http://localhost:3000）
# NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Vercel AI Gateway（仅非 Vercel 部署需要）
# AI_GATEWAY_API_KEY=****

# === SaaS 多租户 & 支付 ===

# Stripe 密钥（测试环境用 sk_test_，生产用 sk_live_）
# 未配置时自动降级为 Mock 模式（直接升级套餐，不跳转支付）
STRIPE_SECRET_KEY=sk_test_****
# Stripe Webhook 签名密钥（用于验证 webhook 请求来源）
STRIPE_WEBHOOK_SECRET=whsec_****
# 站点基础 URL（用于 Stripe checkout/webhook 回跳）
APP_URL=http://localhost:3000

# === 套餐驱动型权限体系 ===
# 4 档套餐：Free(¥0) / Creator(¥29) / Team(¥99) / Enterprise(¥299)
# 套餐配置在 lib/payments/config.ts 中维护，无需环境变量
# 用户套餐存储在 user.planName 字段，通过 /settings 页面升级
